<Window x:Class="Warehouse2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Warehouse2"
        mc:Ignorable="d"
        Title="Складской Учёт" Height="450" Width="455.45" Icon="6103.jpg" ResizeMode="NoResize">
    <Window.Background>
        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
            <GradientStop Color="#FF63480E" Offset="1"/>
            <GradientStop Color="#FFFFC548" Offset="0.14"/>
        </LinearGradientBrush>
    </Window.Background>
    <Grid Margin="0,10,2,1">
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.Background>
            <LinearGradientBrush EndPoint="0.5,1" MappingMode="RelativeToBoundingBox" StartPoint="0.5,0">
                <GradientStop Color="#FFECC542" Offset="0.18"/>
                <GradientStop Color="#FF5F4D11" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>
        <Label Content="Складской учёт" Margin="88,10,63,0" VerticalAlignment="Top" FontFamily="Arial" FontSize="33" Height="57" Background="#00000000" FontWeight="Bold" Foreground="Black" HorizontalAlignment="Center" Grid.ColumnSpan="2" Width="294"/>
        <TextBox x:Name="TBLogin" Grid.ColumnSpan="2" HorizontalAlignment="Left" Height="36" Margin="143,113,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="212" FontFamily="Arial" FontSize="33"/>
        <Button x:Name="BtVhod" Content="Вход" HorizontalAlignment="Left" Margin="199,262,0,0" VerticalAlignment="Top" Width="97" Height="32" Grid.ColumnSpan="2" FontSize="24" FontFamily="Arial" Click="BtVhod_Click">
            <Button.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FF666666" Offset="1"/>
                    <GradientStop Color="White"/>
                </LinearGradientBrush>
            </Button.Background>
        </Button>
        <Label Content="Логин:" HorizontalAlignment="Left" Margin="57,111,0,0" VerticalAlignment="Top" FontSize="24" FontFamily="Arial"/>
        <Label Content="Пароль:" HorizontalAlignment="Left" Margin="38,190,0,0" VerticalAlignment="Top" FontSize="24" FontFamily="Arial"/>
        <Button x:Name="BtExit" Content="Выход" HorizontalAlignment="Left" Margin="99,354,0,0" VerticalAlignment="Top" Width="97" Height="32" FontSize="24" FontFamily="Arial" Grid.Column="1" Click="BtExit_Click">
            <Button.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FF666666" Offset="1"/>
                    <GradientStop Color="White"/>
                </LinearGradientBrush>
            </Button.Background>
        </Button>
        <PasswordBox x:Name="TBPass" HorizontalAlignment="Left" Margin="143,194,0,0" VerticalAlignment="Top" Width="212" FontSize="24" Grid.ColumnSpan="2" Height="34"/>

    </Grid>

</Window>
