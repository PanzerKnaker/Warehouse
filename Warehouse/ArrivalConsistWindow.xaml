<Window x:Class="Warehouse2.ArrivalConsistWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Warehouse2"
        mc:Ignorable="d"
        Title="Окно состава поступлений" Height="597" Width="1350" ResizeMode="NoResize">
    <Window.Background>
        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
            <GradientStop Color="#FF5F4D11" Offset="1"/>
            <GradientStop Color="#FFECC442"/>
        </LinearGradientBrush>
    </Window.Background>
    <Grid>
        <DataGrid x:Name="DGArrivalCons" HorizontalAlignment="Left" Height="558" VerticalAlignment="Top" Width="1016" AutoGenerateColumns="False" SelectionChanged="DGArrivalCons_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Номер поступления" Binding="{Binding NumberArrival}"/>
                <DataGridTextColumn Header="Артикул материала" Binding="{Binding ItemNumber}"/>
                <DataGridTextColumn Header="Количество" Binding="{Binding AmountArr}"/>
                <DataGridTextColumn Header="Объем в куб.м" Binding="{Binding VolumeArr}"/>
            </DataGrid.Columns>
        </DataGrid>
        <TabControl HorizontalAlignment="Left" Height="566" Margin="866,0,0,0" VerticalAlignment="Top" Width="476">
            <TabItem Header="Добавить" Margin="-2,-2,-100,-14" FontFamily="Arial" FontSize="16">
                <TabItem.Background>
                    <LinearGradientBrush EndPoint="0,1" StartPoint="0,0">
                        <GradientStop Color="#FFF0F0F0" Offset="0"/>
                        <GradientStop Color="#FFC1C1C1" Offset="1"/>
                    </LinearGradientBrush>
                </TabItem.Background>
                <Grid Margin="-16,-23,-2,-2">
                    <Grid.Background>
                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                            <GradientStop Color="#FF5F4D11" Offset="1"/>
                            <GradientStop Color="#FFECC542" Offset="0.12"/>
                        </LinearGradientBrush>
                    </Grid.Background>
                    <Label Content="Номер поступления" HorizontalAlignment="Left" Margin="29,79,0,0" VerticalAlignment="Top" FontSize="18"/>
                    <Label Content="Артикул материала" HorizontalAlignment="Left" Margin="29,124,0,0" VerticalAlignment="Top" FontSize="18"/>
                    <Label Content="Колличество" HorizontalAlignment="Left" Margin="29,176,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.323,0.732" FontSize="18"/>
                    <Label Content="Объем в куб.м" HorizontalAlignment="Left" Margin="29,228,0,0" VerticalAlignment="Top" FontSize="18"/>
                    <Button x:Name="BtAddConsArr" Content="Добавить запись" HorizontalAlignment="Left" Margin="173,456,0,0" VerticalAlignment="Top" Width="157"  Height="39" FontSize="18" Background="#FFBDB7B7" Click="BtAddConsArr_Click"/>
                    <ComboBox x:Name="CBNumArr" HorizontalAlignment="Left" Margin="245,81,0,0" VerticalAlignment="Top" Width="199" FontSize="20"/>
                    <ComboBox x:Name="CBNumTovar" HorizontalAlignment="Left" Margin="245,126,0,0" VerticalAlignment="Top" Width="199" FontSize="20"/>
                    <TextBox x:Name="TBAmountArr" HorizontalAlignment="Left" Height="23" Margin="245,184,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="199" FontFamily="Arial" FontSize="20"/>
                    <TextBox x:Name="TBVolumeArr" HorizontalAlignment="Left" Height="23" Margin="245,236,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="199" FontFamily="Arial" FontSize="20"/>
                </Grid>
            </TabItem>
            <TabItem Header="Изменить" Margin="190,0,-282,-16" FontSize="16">
                <TabItem.Background>
                    <LinearGradientBrush EndPoint="0,1" StartPoint="0,0">
                        <GradientStop Color="#FFF0F0F0" Offset="0"/>
                        <GradientStop Color="#FF9B9B9B" Offset="1"/>
                    </LinearGradientBrush>
                </TabItem.Background>
                <Grid Margin="-18,-25,-3,-2">
                    <Grid.Background>
                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                            <GradientStop Color="#FF5F4D11" Offset="1"/>
                            <GradientStop Color="#FFECC542" Offset="0.12"/>
                        </LinearGradientBrush>
                    </Grid.Background>
                    <Button x:Name="BTChangeConsArr" Content="Изменить запись" HorizontalAlignment="Left" Margin="48,464,0,0" VerticalAlignment="Top" Width="182" Height="47" FontFamily="Arial" FontSize="20" Background="#FFBBBBBB" Click="BTChangeConsArr_Click"/>
                    <Button x:Name="TBDelConsArr" Content="Удалить запись" HorizontalAlignment="Left" Margin="272,464,0,0" VerticalAlignment="Top" Width="172" Height="47" Background="#FFB0B0B0" FontFamily="Arial" FontSize="20" Click="TBDelConsArr_Click" />
                    <Label Content="Номер поступления" HorizontalAlignment="Left" Margin="29,79,0,0" VerticalAlignment="Top" FontSize="18"/>
                    <Label Content="Артикул материала" HorizontalAlignment="Left" Margin="29,124,0,0" VerticalAlignment="Top" FontSize="18"/>
                    <Label Content="Колличество" HorizontalAlignment="Left" Margin="29,176,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.323,0.732" FontSize="18"/>
                    <Label Content="Объем в куб.м" HorizontalAlignment="Left" Margin="29,228,0,0" VerticalAlignment="Top" FontSize="18"/>
                    <ComboBox x:Name="CBNumArrEd" HorizontalAlignment="Left" Margin="245,81,0,0" VerticalAlignment="Top" Width="199" FontSize="20"/>
                    <ComboBox x:Name="CBNumTovarEd" HorizontalAlignment="Left" Margin="245,126,0,0" VerticalAlignment="Top" Width="199" FontSize="20"/>
                    <TextBox x:Name="TBAmountArrEd" HorizontalAlignment="Left" Height="23" Margin="245,184,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="199" FontFamily="Arial" FontSize="20"/>
                    <TextBox x:Name="TBVolumeArrEd" HorizontalAlignment="Left" Height="23" Margin="245,236,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="199" FontFamily="Arial" FontSize="20"/>
                </Grid>
            </TabItem>
        </TabControl>

    </Grid>
</Window>
