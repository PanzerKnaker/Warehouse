<Window x:Class="Warehouse2.MeasureWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Warehouse2"
        mc:Ignorable="d"
        Title="Еденицы измерения" Height="450" Width="475.197" ResizeMode="NoResize">
    <Window.Background>
        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
            <GradientStop Color="#FF5F4D11" Offset="1"/>
            <GradientStop Color="#FFECC542"/>
        </LinearGradientBrush>
    </Window.Background>
    <Grid x:Name="BTDelMeasure">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="179*"/>
            <ColumnDefinition Width="288*"/>
        </Grid.ColumnDefinitions>
        <DataGrid x:Name="DGMeasure" HorizontalAlignment="Left" Height="341" VerticalAlignment="Top" Width="231" Grid.ColumnSpan="2" AutoGenerateColumns="False" SelectionChanged="DGMeasure_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Название еденици измерения " Binding="{Binding NameMeasure}"/>
            </DataGrid.Columns>
        </DataGrid>
        <Button x:Name="BTaddMesure" Content="Добавить" HorizontalAlignment="Left" Height="36" Margin="10,357,0,0" VerticalAlignment="Top" Width="135" FontFamily="Arial" FontSize="18" Background="#FFB9B9B9" Click="BTaddMesure_Click"/>
        <Button x:Name="BTChangeMesrue" Content="Изменить" HorizontalAlignment="Left" Height="36" Margin="166,357,0,0" VerticalAlignment="Top" Width="135" FontFamily="Arial" FontSize="18" Grid.ColumnSpan="2" Background="#FFBBBBBB" Click="BTChangeMesrue_Click"/>
        <Button x:Name="BTDelMesure" Content="Удалить" HorizontalAlignment="Left" Height="36" Margin="143,357,0,0" VerticalAlignment="Top" Width="135" FontFamily="Arial" FontSize="18" Grid.Column="1" Background="#FFB2B2B2" Click="BTDelMesure_Click"/>
        <TextBox x:Name="TBNameMeasure" HorizontalAlignment="Left" Height="23" Margin="71,164,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="199" FontFamily="Arial" FontSize="20" Grid.Column="1"/>
        <Label Content="Название еденици измерения" HorizontalAlignment="Left" Margin="68,130,0,0" VerticalAlignment="Top" FontSize="14" Grid.Column="1"/>

    </Grid>
</Window>
