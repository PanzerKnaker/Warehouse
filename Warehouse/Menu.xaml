<Window x:Class="Warehouse2.Menu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Warehouse2"
        mc:Ignorable="d"
        Title="Главное меню" Height="450" Width="800" ResizeMode="NoResize">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.Background>
            <LinearGradientBrush EndPoint="0.5,1" MappingMode="RelativeToBoundingBox" StartPoint="0.5,0">
                <GradientStop Color="#FFECC542" Offset="0.18"/>
                <GradientStop Color="#FF5F4D11" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>
        <Rectangle HorizontalAlignment="Left" Height="419" Margin="159,0,0,0" Stroke="Black" VerticalAlignment="Top" Width="495" Grid.ColumnSpan="2">
            <Rectangle.Fill>
                <ImageBrush ImageSource="6103.jpg"/>
            </Rectangle.Fill>
        </Rectangle>

        <Button Content="Клиенты" HorizontalAlignment="Left" Margin="78,200,0,0" VerticalAlignment="Top" Width="180" FontFamily="Arial" Height="30" FontSize="18" Grid.Column="1" Click="Button_Click_1">
            <Button.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FF666666" Offset="1"/>
                    <GradientStop Color="White"/>
                </LinearGradientBrush>
            </Button.Background>
        </Button>
        <Label Content="Складской учёт" Margin="272,10,241,0" VerticalAlignment="Top" FontFamily="Arial" FontSize="33" Grid.ColumnSpan="2" Height="57" Background="#00000000" FontWeight="Bold" HorizontalAlignment="Center" Width="281">
            <Label.Foreground>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FFCFAD3C" Offset="0"/>
                    <GradientStop Color="#FFFFFEFC" Offset="1"/>
                </LinearGradientBrush>
            </Label.Foreground>
        </Label>
        <Button x:Name="ButtonSup" Content="Поставщики" HorizontalAlignment="Left" Margin="78,146,0,0" VerticalAlignment="Top" Width="180" FontFamily="Arial" Height="30" FontSize="18" Grid.Column="1" Click="Button_Click">
            <Button.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FF666666" Offset="1"/>
                    <GradientStop Color="White"/>
                </LinearGradientBrush>
            </Button.Background>
        </Button>
        <Button x:Name="BTOrder" Content="Расход материалов" HorizontalAlignment="Left" Margin="159,200,0,0" VerticalAlignment="Top" Width="180" FontFamily="Arial" Height="30" FontSize="18" Click="BTOrder_Click">
            <Button.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FF666666" Offset="1"/>
                    <GradientStop Color="White"/>
                </LinearGradientBrush>
            </Button.Background>
        </Button>
        <Button x:Name="BTTovar" Content="Мтериалы" HorizontalAlignment="Left" Margin="159,146,0,0" VerticalAlignment="Top" Width="180" FontFamily="Arial" Height="30" FontSize="18" Click="BTTovar_Click">
            <Button.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FF666666" Offset="1"/>
                    <GradientStop Color="White"/>
                </LinearGradientBrush>
            </Button.Background>
        </Button>
        <Label Content="строительной организации" Margin="175,52,135,0" VerticalAlignment="Top" FontFamily="Arial" FontSize="33" Grid.ColumnSpan="2" Height="57" Background="#00000000" FontWeight="Bold" HorizontalAlignment="Center" Width="484">
            <Label.Foreground>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FFCFAD3C" Offset="0"/>
                    <GradientStop Color="#FFFFFEFC" Offset="1"/>
                </LinearGradientBrush>
            </Label.Foreground>
        </Label>
        <Button x:Name="BTExit" Content="Выход" HorizontalAlignment="Left" Margin="78,354,0,0" VerticalAlignment="Top" Width="179" FontFamily="Arial" Height="30" FontSize="18" Grid.Column="1" Click="BTExit_Click" >
            <Button.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FF666666" Offset="1"/>
                    <GradientStop Color="White"/>
                </LinearGradientBrush>
            </Button.Background>
        </Button>
        <Button x:Name="BTArrival"  Content="Приход материалов" HorizontalAlignment="Left" Margin="159,258,0,0" VerticalAlignment="Top" Width="180" FontFamily="Arial" Height="30" FontSize="18" Click="BTArrival_Click">
            <Button.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FF666666" Offset="1"/>
                    <GradientStop Color="White"/>
                </LinearGradientBrush>
            </Button.Background>
        </Button>
        <Button x:Name="BTEmp" Content="Сотрудники" HorizontalAlignment="Left" Margin="78,258,0,0" VerticalAlignment="Top" Width="180" FontFamily="Arial" Height="30" FontSize="18" Grid.Column="1" Click="BTEmp_Click">
            <Button.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FF666666" Offset="1"/>
                    <GradientStop Color="White"/>
                </LinearGradientBrush>
            </Button.Background>
        </Button>
        <Label x:Name="LBName" Content="Label" HorizontalAlignment="Left" Margin="183,341,0,0" VerticalAlignment="Top" Width="162" Foreground="#FFE6E699" FontSize="16" FontWeight="Bold"/>
        <Label x:Name="LBwell" Content="Здравствуйте" HorizontalAlignment="Left" Margin="184,310,0,0" VerticalAlignment="Top" Width="161" Foreground="#FFE6E699" FontSize="16" FontWeight="Bold"/>
        <Label x:Name="LBPost" Content="Label" HorizontalAlignment="Left" Margin="183,372,0,0" VerticalAlignment="Top" Width="162" Foreground="#FFE6E699" FontSize="16" FontWeight="Bold"/>
        <Button x:Name="BTExitAcc" Content="Выход из учётной записи" HorizontalAlignment="Left" Margin="10,354,0,0" VerticalAlignment="Top" Width="144" FontFamily="Arial" Height="30" Click="BTExitAcc_Click" >
            <Button.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FF595959" Offset="1"/>
                    <GradientStop Color="White"/>
                    <GradientStop Color="#FF020202" Offset="1"/>
                </LinearGradientBrush>
            </Button.Background>
        </Button>

    </Grid>

</Window>
