<Window x:Class="Warehouse2.SuplierWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Warehouse2"
        mc:Ignorable="d"
        Title="Окно поставщиков" Height="597" Width="1500" ResizeMode="NoResize">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="61*"/>
            <ColumnDefinition Width="203*"/>
        </Grid.ColumnDefinitions>
        <Grid.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Color="#FF5F4D11" Offset="1"/>
                <GradientStop Color="#FFECC542" Offset="0.147"/>
            </LinearGradientBrush>
        </Grid.Background>
        <DataGrid x:Name="DGSuplier" HorizontalAlignment="Left" Height="519" VerticalAlignment="Top" Width="1016" Grid.ColumnSpan="2" AutoGenerateColumns="False" SelectionChanged="DGSuplier_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Название организации" Binding="{Binding NameSup}"/>
                <DataGridTextColumn Header="Обращяться к" Binding="{Binding ReferTo}"/>
                <DataGridTextColumn Header="Должность" Binding="{Binding Post}"/>
                <DataGridTextColumn Header="Адрес" Binding="{Binding Adress}"/>
                <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}"/>
                <DataGridTextColumn Header="Факс" Binding="{Binding Fax}"/>
                <DataGridTextColumn Header="Электронная почта" Binding="{Binding EMail}"/>
            </DataGrid.Columns>
        </DataGrid>
        <TabControl HorizontalAlignment="Left" Height="566" Margin="671,0,0,0" VerticalAlignment="Top" Width="476" Grid.Column="1">
            <TabItem Header="Добавить" Margin="-2,-2,-100,-14" FontFamily="Arial" FontSize="16">
                <TabItem.Background>
                    <LinearGradientBrush EndPoint="0,1" StartPoint="0,0">
                        <GradientStop Color="#FFF0F0F0" Offset="0"/>
                        <GradientStop Color="#FFC1C1C1" Offset="1"/>
                    </LinearGradientBrush>
                </TabItem.Background>
                <Grid Margin="-18,-20,0,-5">
                    <Grid.Background>
                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                            <GradientStop Color="#FF5F4D11" Offset="1"/>
                            <GradientStop Color="#FFECC542" Offset="0.12"/>
                        </LinearGradientBrush>
                    </Grid.Background>
                    <TextBox x:Name="TBNameSup" HorizontalAlignment="Left" Height="23" Margin="245,84,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="199" FontFamily="Arial" FontSize="20"/>
                    <TextBox x:Name="TBReferSup" HorizontalAlignment="Left" Height="23" Margin="245,132,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="199" FontFamily="Arial" FontSize="20"/>
                    <TextBox x:Name="TBPostSup" HorizontalAlignment="Left" Height="23" Margin="245,184,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="199" FontFamily="Arial" FontSize="20"/>
                    <TextBox x:Name="TBAdresSup" HorizontalAlignment="Left" Height="23" Margin="245,236,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="199" FontFamily="Arial" FontSize="20"/>
                    <TextBox x:Name="TBNumSup" HorizontalAlignment="Left" Height="23" Margin="245,288,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="199" FontFamily="Arial" FontSize="20"/>
                    <TextBox x:Name="TBFaxSup" HorizontalAlignment="Left" Height="23" Margin="245,344,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="199" FontFamily="Arial" FontSize="20"/>
                    <TextBox x:Name="TBEmailSup" HorizontalAlignment="Left" Height="23" Margin="245,400,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="199" FontFamily="Arial" FontSize="20"/>
                    <Label Content="Название организации" HorizontalAlignment="Left" Margin="29,79,0,0" VerticalAlignment="Top" FontSize="18"/>
                    <Label Content="Обращаться к" HorizontalAlignment="Left" Margin="29,124,0,0" VerticalAlignment="Top" FontSize="18"/>
                    <Label Content="Должность" HorizontalAlignment="Left" Margin="29,176,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.323,0.732" FontSize="18"/>
                    <Label Content="Адрес" HorizontalAlignment="Left" Margin="29,228,0,0" VerticalAlignment="Top" FontSize="18"/>
                    <Label Content="Телефон" HorizontalAlignment="Left" Margin="29,280,0,0" VerticalAlignment="Top" FontSize="18"/>
                    <Label Content="Факс" HorizontalAlignment="Left" Margin="29,336,0,0" VerticalAlignment="Top" FontSize="18"/>
                    <Label Content="Электронная почта" HorizontalAlignment="Left" Margin="29,392,0,0" VerticalAlignment="Top" FontSize="18"/>
                    <Button x:Name="BtSupAdd" Content="Добавить запись" HorizontalAlignment="Left" Margin="173,456,0,0" VerticalAlignment="Top" Width="157" Click="BtSupAdd_Click" Height="39" FontSize="18" Background="#FFBDB7B7"/>
                </Grid>
            </TabItem>
            <TabItem Header="Изменить" Margin="190,0,-282,-16" FontSize="16">
                <TabItem.Background>
                    <LinearGradientBrush EndPoint="0,1" StartPoint="0,0">
                        <GradientStop Color="#FFF0F0F0" Offset="0"/>
                        <GradientStop Color="#FF9B9B9B" Offset="1"/>
                    </LinearGradientBrush>
                </TabItem.Background>
                <Grid Margin="-18,-25,-3,-2">
                    <Grid.Background>
                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                            <GradientStop Color="#FF5F4D11" Offset="1"/>
                            <GradientStop Color="#FFECC542" Offset="0.12"/>
                        </LinearGradientBrush>
                    </Grid.Background>
                    <TextBox x:Name="SupNameEd" HorizontalAlignment="Left" Height="23" Margin="245,84,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="199" FontFamily="Arial" FontSize="20"/>
                    <TextBox x:Name="SupReferEd" HorizontalAlignment="Left" Height="23" Margin="245,132,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="199" FontFamily="Arial" FontSize="20"/>
                    <TextBox x:Name="SupPostEd" HorizontalAlignment="Left" Height="23" Margin="245,184,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="199" FontFamily="Arial" FontSize="20"/>
                    <TextBox x:Name="SupAdresEd" HorizontalAlignment="Left" Height="23" Margin="245,236,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="199" FontFamily="Arial" FontSize="20"/>
                    <TextBox x:Name="SupPhoneEd" HorizontalAlignment="Left" Height="23" Margin="245,288,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="199" FontFamily="Arial" FontSize="20"/>
                    <TextBox x:Name="SupFaxEd" HorizontalAlignment="Left" Height="23" Margin="245,344,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="199" FontFamily="Arial" FontSize="20"/>
                    <TextBox x:Name="SupEmailEd" HorizontalAlignment="Left" Height="23" Margin="245,400,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="199" FontFamily="Arial" FontSize="20"/>
                    <Label Content="Название организации" HorizontalAlignment="Left" Margin="29,79,0,0" VerticalAlignment="Top" FontSize="18"/>
                    <Label Content="Обращаться к" HorizontalAlignment="Left" Margin="29,124,0,0" VerticalAlignment="Top" FontSize="18"/>
                    <Label Content="Должность" HorizontalAlignment="Left" Margin="29,176,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.323,0.732" FontSize="18"/>
                    <Label Content="Адрес" HorizontalAlignment="Left" Margin="29,228,0,0" VerticalAlignment="Top" FontSize="18"/>
                    <Label Content="Телефон" HorizontalAlignment="Left" Margin="29,280,0,0" VerticalAlignment="Top" FontSize="18"/>
                    <Label Content="Факс" HorizontalAlignment="Left" Margin="29,336,0,0" VerticalAlignment="Top" FontSize="18"/>
                    <Label Content="Электронная почта" HorizontalAlignment="Left" Margin="29,392,0,0" VerticalAlignment="Top" FontSize="18"/>
                    <Button x:Name="BTChangeSup" Content="Изменить запись" HorizontalAlignment="Left" Margin="48,464,0,0" VerticalAlignment="Top" Width="182" Height="47" FontFamily="Arial" FontSize="20" Background="#FFBBBBBB" Click="BTChangeSup_Click"/>
                    <Button x:Name="TbSupDel" Content="Удалить запись" HorizontalAlignment="Left" Margin="272,464,0,0" VerticalAlignment="Top" Width="172" Height="47" Background="#FFB0B0B0" FontFamily="Arial" FontSize="20" Click="TbSupDel_Click"/>
                </Grid>
            </TabItem>
        </TabControl>
        <Button x:Name="BTBack" Content="Назад" HorizontalAlignment="Left" Margin="28,524,0,0" VerticalAlignment="Top" Width="135" Height="32" FontFamily="Arial" FontSize="20" Background="#FFB9B7B7" Click="BTBack_Click"/>

    </Grid>
</Window>
