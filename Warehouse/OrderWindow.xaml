<Window x:Class="Warehouse2.OrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Warehouse2"
        mc:Ignorable="d"
        Title="Окно расхода материалов" Height="594" Width="1350" ResizeMode="NoResize">
    <Window.Background>
        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
            <GradientStop Color="#FF5F4D11" Offset="1"/>
            <GradientStop Color="#FFECC342"/>
        </LinearGradientBrush>
    </Window.Background>
    <Grid>
        <DataGrid x:Name="DGOrder" HorizontalAlignment="Left" Height="519" VerticalAlignment="Top" Width="1016" AutoGenerateColumns="False" SelectionChanged="DGOrder_SelectionChanged" Background="#FFFFFFAE">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Номер расхода" Binding="{Binding IDOrder}" />
                <DataGridTextColumn Header="Заказчик" Binding="{Binding Clients.NameClient}" />
                <DataGridTextColumn Header="Материалы отпустил" Binding="{Binding Employees.SurnameEmp}"/>
                <DataGridTextColumn Header="Дата отгрузки" Binding="{Binding ShippingDate }" />
                <DataGridTextColumn Header="Имя получателя" Binding="{Binding RecipientName}" />
                <DataGridTextColumn Header="Адрес получателя" Binding="{Binding RecipientAdress}"/>
            </DataGrid.Columns>
        </DataGrid>
        <TabControl HorizontalAlignment="Left" Height="566" Margin="866,0,0,-46" VerticalAlignment="Top" Width="476">
            <TabItem Header="Добавить" Margin="-2,-2,-100,-14" FontFamily="Arial" FontSize="16">
                <TabItem.Background>
                    <LinearGradientBrush EndPoint="0,1" StartPoint="0,0">
                        <GradientStop Color="#FFF0F0F0"/>
                        <GradientStop Color="#FF878787" Offset="1"/>
                    </LinearGradientBrush>
                </TabItem.Background>
                <Grid Margin="-16,-23,-2,-2">
                    <Grid.Background>
                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                            <GradientStop Color="#FF5F4D11" Offset="1"/>
                            <GradientStop Color="#FFECC542" Offset="0.12"/>
                        </LinearGradientBrush>
                    </Grid.Background>
                    <TextBox x:Name="TBNumOrd" HorizontalAlignment="Left" Height="23" Margin="245,84,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="199" FontFamily="Arial" FontSize="20"/>
                    <Label Content="Номер Расхода" HorizontalAlignment="Left" Margin="29,79,0,0" VerticalAlignment="Top" FontSize="18"/>
                    <Label Content="Заказчик" HorizontalAlignment="Left" Margin="29,124,0,0" VerticalAlignment="Top" FontSize="18"/>
                    <Label Content="Материалы отпустил" HorizontalAlignment="Left" Margin="29,176,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.323,0.732" FontSize="18"/>
                    <Label Content="Дата отгрузки" HorizontalAlignment="Left" Margin="29,228,0,0" VerticalAlignment="Top" FontSize="18"/>
                    <Button x:Name="BtAddOrd" Content="Добавить запись" HorizontalAlignment="Left" Margin="34,448,0,0" VerticalAlignment="Top" Width="157"  Height="39" FontSize="18" Click="BtAddOrd_Click">
                        <Button.Background>
                            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                <GradientStop Color="#FF878787" Offset="1"/>
                                <GradientStop Color="White"/>
                            </LinearGradientBrush>
                        </Button.Background>
                    </Button>
                    <ComboBox DisplayMemberPath="NameClient" x:Name="CBCliOrd" HorizontalAlignment="Left" Margin="245,126,0,0" VerticalAlignment="Top" Width="199" FontSize="20" SelectedIndex="0"/>
                    <ComboBox DisplayMemberPath="SurnameEmp" x:Name="CBEmpOrd" HorizontalAlignment="Left" Margin="245,178,0,0" VerticalAlignment="Top" Width="199" FontSize="20" SelectedIndex="0"/>
                    <DatePicker x:Name="DPDateOrd" HorizontalAlignment="Left" Margin="245,227,0,0" VerticalAlignment="Top" Width="198" Height="32" FontSize="20" SelectedDateFormat="Short" Text="yy.dd.mm" />
                    <TextBox x:Name="TBNameOrd" HorizontalAlignment="Left" Height="23" Margin="245,269,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="199" FontFamily="Arial" FontSize="20"/>
                    <Label Content="Имя получателя" HorizontalAlignment="Left" Margin="29,264,0,0" VerticalAlignment="Top" FontSize="18"/>
                    <TextBox x:Name="TBAdressOrd" HorizontalAlignment="Left" Height="23" Margin="245,305,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="199" FontFamily="Arial" FontSize="20"/>
                    <Label Content="Адрес получателя" HorizontalAlignment="Left" Margin="29,300,0,0" VerticalAlignment="Top" FontSize="18"/>
                    <Button x:Name="BtЗPechOrd" Content="Выгрузить данные" HorizontalAlignment="Left" Margin="286,448,0,0" VerticalAlignment="Top" Width="179"  Height="39" FontSize="18" Click="BtЗPechOrd_Click">
                        <Button.Background>
                            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                <GradientStop Color="#FF878787" Offset="1"/>
                                <GradientStop Color="White"/>
                            </LinearGradientBrush>
                        </Button.Background>
                    </Button>
                </Grid>
            </TabItem>
            <TabItem Header="Изменить" Margin="190,0,-282,-16" FontSize="16">
                <TabItem.Background>
                    <LinearGradientBrush EndPoint="0,1" StartPoint="0,0">
                        <GradientStop Color="#FFF0F0F0"/>
                        <GradientStop Color="#FF878787" Offset="1"/>
                    </LinearGradientBrush>
                </TabItem.Background>
                <Grid Margin="-18,-25,-3,-2">
                    <Grid.Background>
                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                            <GradientStop Color="#FF5F4D11" Offset="1"/>
                            <GradientStop Color="#FFECC542" Offset="0.12"/>
                        </LinearGradientBrush>
                    </Grid.Background>
                    <Button x:Name="BTChangeArr" Content="Изменить запись" HorizontalAlignment="Left" Margin="48,464,0,0" VerticalAlignment="Top" Width="182" Height="47" FontFamily="Arial" FontSize="20" Click="BTChangeArr_Click">
                        <Button.Background>
                            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                <GradientStop Color="#FF878787" Offset="1"/>
                                <GradientStop Color="White"/>
                            </LinearGradientBrush>
                        </Button.Background>
                    </Button>
                    <Button x:Name="TBDelArr" Content="Удалить запись" HorizontalAlignment="Left" Margin="272,464,0,0" VerticalAlignment="Top" Width="172" Height="47" FontFamily="Arial" FontSize="20" Click="TBDelArr_Click" >
                        <Button.Background>
                            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                <GradientStop Color="#FF878787" Offset="1"/>
                                <GradientStop Color="White"/>
                            </LinearGradientBrush>
                        </Button.Background>
                    </Button>
                    <TextBox x:Name="TBNumOrdEd" HorizontalAlignment="Left" Height="23" Margin="245,84,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="199" FontFamily="Arial" FontSize="20"/>
                    <Label Content="Номер Расхода" HorizontalAlignment="Left" Margin="29,79,0,0" VerticalAlignment="Top" FontSize="18"/>
                    <Label Content="Заказчик" HorizontalAlignment="Left" Margin="29,124,0,0" VerticalAlignment="Top" FontSize="18"/>
                    <Label Content="Материалы отпустил" HorizontalAlignment="Left" Margin="29,176,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.323,0.732" FontSize="18"/>
                    <Label Content="Дата отгрузки" HorizontalAlignment="Left" Margin="29,228,0,0" VerticalAlignment="Top" FontSize="18"/>
                    <ComboBox DisplayMemberPath="NameClient" x:Name="CBCliOrdEd" HorizontalAlignment="Left"  Margin="245,126,0,0" VerticalAlignment="Top" Width="199" FontSize="20" SelectedIndex="0"/>
                    <ComboBox DisplayMemberPath="SurnameEmp" x:Name="CBEmpOrdEd" HorizontalAlignment="Left" Margin="245,178,0,0" VerticalAlignment="Top" Width="199" FontSize="20" SelectedIndex="0"/>
                    <DatePicker x:Name="DPDateOrdEd" HorizontalAlignment="Left" Margin="245,227,0,0" VerticalAlignment="Top" Width="198" Height="32" FontSize="20" />
                    <TextBox x:Name="TBNameOrdEd" HorizontalAlignment="Left" Height="23" Margin="245,269,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="199" FontFamily="Arial" FontSize="20"/>
                    <Label Content="Имя получателя" HorizontalAlignment="Left" Margin="29,264,0,0" VerticalAlignment="Top" FontSize="18"/>
                    <TextBox x:Name="TBAdressOrdEd" HorizontalAlignment="Left" Height="23" Margin="245,305,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="199" FontFamily="Arial" FontSize="20"/>
                    <Label Content="Адрес получателя" HorizontalAlignment="Left" Margin="29,300,0,0" VerticalAlignment="Top" FontSize="18"/>
                </Grid>
            </TabItem>
        </TabControl>
        <Button x:Name="BTBackOrd" Content="Назад" HorizontalAlignment="Left" Margin="28,524,0,-36" VerticalAlignment="Top" Width="135" Height="32" FontFamily="Arial" FontSize="20" Click="BTBackOrd_Click" >
            <Button.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FF878787" Offset="1"/>
                    <GradientStop Color="White"/>
                </LinearGradientBrush>
            </Button.Background>
        </Button>
        <Button x:Name="BTOrdered" Content="Таблица состава расходов" HorizontalAlignment="Left" Margin="494,524,0,-36" VerticalAlignment="Top" Width="367" Height="32" FontFamily="Arial" FontSize="20" Click="BTOrdered_Click" >
            <Button.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FF878787" Offset="1"/>
                    <GradientStop Color="White"/>
                </LinearGradientBrush>
            </Button.Background>
        </Button>

    </Grid>
</Window>
